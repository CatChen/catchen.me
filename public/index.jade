doctype
html
  head
    script
      | var languages;
      | if (Object.prototype.toString.call(navigator.languages) === '[object Array]') {
      |   languages = navigator.languages;
      | } else if (typeof navigator.language === 'string') {
      |   languages = [navigator.language];
      | }
      | var pathname = '/en/';
      | for (var i = 0; i < languages.length; i++) {
      |   var matches = languages[i].match(/^(zh|en)/);
      |   if (matches) {
      |     pathname = '/' + matches[1] + '/';
      |     break;
      |   }
      | }
      | window.location.pathname = pathname;
    meta(http-equiv="Content-Type" content="text/html; charset=utf-8")
    meta(name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no,viewport-fit=cover")
    meta(name="description" content="Personal website of Cat Chen (aka catchen). Find Cat's resume, projects, services, and writing here.")
    meta(property="og:type" content="profile")
    meta(property="og:title" content="Cat Chen (aka catchen)")
    meta(property="og:description" content="Personal website of Cat Chen (aka catchen). Find Cat's resume, projects, services, and writing here.")
    meta(property="og:url" content="https://catchen.me/")
    meta(property="og:image" content="https://catchen.me/images/profile_picture_360_360_1x.jpg")
    meta(property="fb:profile_id" content="504867629")
    meta(property="fb:pages" content="319695031499949")
    link(rel="canonical" href="https://catchen.me/")
    != partial('_helpers/structuredData')
    title
      | Cat Chen (aka catchen) | 陈广琛
  body
    noscript
      h1
        | #{public._data.index.heading}
      p
        | #{public._data.index.introduction.text}
      h2
        | Languages
      ul
        for data, locale in public._data.locales
          li
            a(
              href="/#{locale}/"
            ) #{public._data.locales[locale][locale].title}
      h2
        | Pages
      ul
        for page in public._data.pages
          - var pagePath = page.replace(/^index$/, '');
          - var pageData = public._data[page] || {};
          li
            a(
              href="/en/#{pagePath}"
            ) #{pageData.title}
